# Only track .claude/ infrastructure — everything else is local
# creekside-tools and creekside-dashboard are separate repos outside this directory
*
!.gitignore
!CLAUDE.md
!README.md
!.claude/
!.claude/**

# Never push secrets or old git data
.claude/settings.local.json
.claude/ADMIN_MODE
.claude/.git-old/

# Temp/logs
*.log
plans/
